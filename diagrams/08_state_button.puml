@startuml 08_State_Button
left to right direction
skinparam linetype ortho

skinparam BackgroundColor        #FAFAFA
skinparam ArrowColor             #336699
skinparam ArrowThickness         1.5
skinparam StateBackgroundColor   #DDEEFF
skinparam StateBorderColor       #336699
skinparam StateFontSize          13
skinparam StateAttributeFontSize 11
skinparam noteBackgroundColor    #FFFDE7
skinparam noteBorderColor        #F9A825
skinparam noteFontSize           11
skinparam defaultTextAlignment   left
skinparam Padding                8
skinparam RoundCorner            8

title State Diagram – Button Control  (src/drivers/button_control.cpp)

' ─── Boot / setupButton() ────────────────────────────────────────────────────
[*] --> INIT

state INIT : do   / buttonPrefs.begin("button_cfg", true)
state INIT : do   / buttonEnabled = getBool("enabled", true)
state INIT : do   / pinMode(BUTTON_PIN, INPUT)
state INIT : exit / buttonState = digitalRead(BUTTON_PIN)

INIT --> ENABLED  : [buttonEnabled == true]
INIT --> DISABLED : [buttonEnabled == false]

' ─── ENABLED superstate ──────────────────────────────────────────────────────
state ENABLED {
    [*] --> IDLE

    state IDLE : isr_triggered = false
    state IDLE : returns (buttonState == LOW)

    state DEBOUNCING : isr_triggered = true
    state DEBOUNCING : isr_time_ms = millis() on each edge
    state DEBOUNCING : returns old buttonState

    IDLE       --> DEBOUNCING : buttonISR() / CHANGE
    DEBOUNCING --> DEBOUNCING : buttonISR() / bounce
    DEBOUNCING --> IDLE       : [millis()-isr_time_ms >= 25 ms]\n/ buttonState = digitalRead()
}

note top of ENABLED
  IDLE → DEBOUNCING:
    isr_triggered = true
    isr_time_ms   = millis()
  DEBOUNCING → IDLE:
    isr_triggered = false
    buttonState   = digitalRead(BUTTON_PIN)
end note

' ─── DISABLED state ──────────────────────────────────────────────────────────
state DISABLED : no interrupt attached
state DISABLED : getButtonState() → always false

' ─── Enable / Disable ────────────────────────────────────────────────────────
ENABLED  --> DISABLED : setButtonEnabled(false)
DISABLED --> ENABLED  : setButtonEnabled(true)

note bottom of ENABLED
  setButtonEnabled(false):
    detachInterrupt()
    NVS.putBool("enabled", false)
  setButtonEnabled(true):
    attachInterrupt(CHANGE)
    isr_triggered = false
    buttonState   = digitalRead()
    NVS.putBool("enabled", true)
end note

note bottom of DISABLED
  setButtonEnabled() called from:
  HTTP  GET /setButtonEnabled?enabled=0|1
  UART  "button enable" / "button disable"
  NVS   namespace "button_cfg", key "enabled"
end note

@enduml
